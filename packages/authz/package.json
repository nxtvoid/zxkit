{
  "name": "@zxkit/authz",
  "version": "1.0.0",
  "description": "Storage-agnostic roles, permissions, guards, and server authorization helpers",
  "author": "nxtvoid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nxtvoid/zxkit",
    "directory": "packages/authz"
  },
  "keywords": [
    "authz",
    "authorization",
    "permissions",
    "roles",
    "rbac",
    "react",
    "nextjs"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "authz": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "default": "./dist/react.mjs"
    },
    "./next": {
      "types": "./dist/next.d.mts",
      "default": "./dist/next.mjs"
    },
    "./core": {
      "types": "./dist/core/index.d.mts",
      "default": "./dist/core/index.mjs"
    },
    "./cache": {
      "types": "./dist/cache/index.d.mts",
      "default": "./dist/cache/index.mjs"
    },
    "./prisma": {
      "types": "./dist/prisma.d.mts",
      "default": "./dist/prisma.mjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.mts",
      "default": "./dist/adapters/index.mjs"
    },
    "./adapters/prisma": {
      "types": "./dist/adapters/prisma.d.mts",
      "default": "./dist/adapters/prisma.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "bugs": {
    "url": "https://github.com/nxtvoid/zxkit/issues"
  },
  "homepage": "https://github.com/nxtvoid/zxkit/tree/main/packages/authz#readme",
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9.32.0",
    "jsdom": "^26.1.0",
    "next": "^16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
