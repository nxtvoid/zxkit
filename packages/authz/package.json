{
  "name": "@zxkit/authz",
  "version": "1.0.0",
  "description": "Storage-agnostic roles, permissions, guards, and server authorization helpers",
  "author": "nxtvoid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nxtvoid/zxkit.git#main"
  },
  "keywords": [
    "authz",
    "authorization",
    "permissions",
    "roles",
    "rbac",
    "react",
    "nextjs"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "authz": "dist/cli.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./cache": {
      "import": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.js"
      },
      "require": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.cjs"
      }
    },
    "./prisma": {
      "import": {
        "types": "./dist/prisma.d.ts",
        "default": "./dist/prisma.js"
      },
      "require": {
        "types": "./dist/prisma.d.ts",
        "default": "./dist/prisma.cjs"
      }
    },
    "./adapters": {
      "import": {
        "types": "./dist/adapters/index.d.ts",
        "default": "./dist/adapters/index.js"
      },
      "require": {
        "types": "./dist/adapters/index.d.ts",
        "default": "./dist/adapters/index.cjs"
      }
    },
    "./adapters/prisma": {
      "import": {
        "types": "./dist/adapters/prisma.d.ts",
        "default": "./dist/adapters/prisma.js"
      },
      "require": {
        "types": "./dist/adapters/prisma.d.ts",
        "default": "./dist/adapters/prisma.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "rollup -c --watch",
    "build": "bun run clean && rollup -c",
    "clean": "bun -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "bugs": {
    "url": "https://github.com/nxtvoid/zxkit/issues"
  },
  "homepage": "https://github.com/nxtvoid/zxkit/tree/main/packages/authz#readme",
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9.32.0",
    "jsdom": "^26.1.0",
    "next": "^16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-preserve-directives": "^1.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
